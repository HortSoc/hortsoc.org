---
const title = "Hortsoc Admin";
const netlifyAdminUrl = "https://hortsoc.netlify.app/admin/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        font-family: system-ui, sans-serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: #f3f3f7;
      }

      .admin-gate {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        box-sizing: border-box;
      }

      .admin-gate-card {
        width: min(26rem, 100%);
        padding: 2rem 1.5rem;
        background: #ffffff;
        box-shadow: 0 18px 40px rgba(33, 36, 44, 0.1);
        text-align: center;
      }

      .admin-gate-card h1 {
        margin: 0 0 0.8rem;
        font-size: 1.6rem;
      }

      .admin-gate-card p {
        margin: 0 0 1.5rem;
        color: #52565f;
        line-height: 1.5;
      }

      .admin-login-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 13rem;
        padding: 0.85rem 1.1rem;
        border: 0;
        background: #2d333b;
        color: #ffffff;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .admin-login-button:hover,
      .admin-login-button:focus-visible {
        background: #1f252c;
      }

      .admin-status {
        margin-top: 1rem;
        color: #52565f;
        font-size: 0.95rem;
      }

      .admin-help-link {
        color: #2d333b;
        font-weight: 700;
      }

      .admin-gate.is-hidden {
        display: none;
      }
    </style>
  </head>
  <body>
    <main class="admin-gate">
      <section class="admin-gate-card">
        <h1>Hortsoc Admin</h1>
        <p>Log in with GitHub to edit the website.</p>
        <button type="button" class="admin-login-button">Login with GitHub</button>
        <p class="admin-status">You will continue via Netlify Identity.</p>
        <p>
          Editors can also open
          <a class="admin-help-link" href={netlifyAdminUrl}>{netlifyAdminUrl}</a>
          directly.
        </p>
      </section>
    </main>

    <script is:inline>
      (() => {
        const netlifyAdminUrl = "https://hortsoc.netlify.app/admin/";
        const gate = document.querySelector(".admin-gate");
        const loginButton = document.querySelector(".admin-login-button");
        const statusNode = document.querySelector(".admin-status");

        function setStatus(message) {
          if (statusNode) {
            statusNode.textContent = message;
          }
        }

        function loadScript(src, onload, onerror) {
          const script = document.createElement("script");
          script.src = src;
          script.onload = onload ?? null;
          script.onerror = onerror ?? null;
          document.head.appendChild(script);
        }

        const isNetlifyAdminHost = window.location.origin === "https://hortsoc.netlify.app";
        if (!isNetlifyAdminHost) {
          loginButton?.addEventListener("click", () => {
            window.location.href = netlifyAdminUrl;
          });
          setStatus("CMS login is hosted on Netlify. Use the button above to continue.");
          return;
        }

        gate.classList.add("is-hidden");

        const loadingCard = document.createElement("main");
        loadingCard.className = "admin-gate";
        loadingCard.innerHTML = `
          <section class="admin-gate-card">
            <h1>Hortsoc Admin</h1>
            <p class="admin-status">Loading CMS…</p>
          </section>
        `;
        document.body.appendChild(loadingCard);

        loadScript(
          "https://identity.netlify.com/v1/netlify-identity-widget.js",
          () => {
            loadScript(
              "https://unpkg.com/decap-cms@^3.8.3/dist/decap-cms.js",
              () => {
                loadingCard.remove();
              },
              () => {
                const node = loadingCard.querySelector(".admin-status");
                if (node) {
                  node.textContent = "Decap CMS failed to load.";
                }
              },
            );
          },
          () => {
            const node = loadingCard.querySelector(".admin-status");
            if (node) {
              node.textContent = "Netlify Identity failed to load.";
            }
          },
        );
      })();
    </script>
  </body>
</html>
